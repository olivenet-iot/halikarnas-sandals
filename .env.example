# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/halikarnas?schema=public"

# Site URL (used by metadata, sitemap, email templates, SITE_URL single source)
NEXT_PUBLIC_SITE_URL="https://halikarnassandals.com"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_STRONG_SECRET_FROM_OPENSSL"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Resend (Email)
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
ADMIN_EMAIL="info@halikarnassandals.com"
SUPPORT_EMAIL="destek@halikarnassandals.com"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Redis (rate limiting)
REDIS_URL="redis://localhost:6379"

# Error tracking (leave empty for no-op mode — set on deploy)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
